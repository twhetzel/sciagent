# SciAgent Studio environment variables

# Server
SCIAGENT_HOST=127.0.0.1
SCIAGENT_PORT=8000
SCIAGENT_WORKERS=1
SCIAGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://localhost:8080

# NCBI E-utilities (PubMed, ClinVar) — recommended for production
PUBMED_EMAIL=
PUBMED_TOOL=sciagent_studio

# GEO dataset discovery — max records to retrieve and rank per query (default 15, cap 200)
GEO_MAX_RESULTS=50

# OpenAlex politeness
OPENALEX_EMAIL=

# Optional LLM summarization and ontology synonym expansion (tier 3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# BioPortal ontology lookup (tier 2) — free at bioportal.bioontology.org
BIOPORTAL_API_KEY=
MAX_TOKENS=1000
TEMPERATURE=0.7

# Frontend (Vercel build-time only)
# VITE_API_BASE=https://your-render-service.onrender.com
