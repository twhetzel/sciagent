# SciAgent Studio environment variables

# Server
SCIAGENT_HOST=127.0.0.1
SCIAGENT_PORT=8000
SCIAGENT_WORKERS=1
SCIAGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://localhost:8080

# Optional deployment blocklist for external data sources (comma-separated, no spaces).
# If you include spaces, quote the value: SCIAGENT_EXCLUDED_SOURCES="expression_atlas, geo_dataset_search"
# Unset = all built-in sources enabled.
# SCIAGENT_EXCLUDED_SOURCES=openalex,europepmc,expression_atlas,clinvar,alphafold,geo_dataset_search

# Optional deployment blocklist for agent tools (comma-separated).
# Unset = all built-in tools enabled. Example: summarize
# SCIAGENT_EXCLUDED_TOOLS=summarize

# NCBI E-utilities (PubMed, ClinVar, GEO, etc.) — recommended for production
NCBI_EMAIL=
# Legacy fallback if NCBI_EMAIL is unset:
# PUBMED_EMAIL=
PUBMED_TOOL=sciagent_studio
# From https://www.ncbi.nlm.nih.gov/account/settings/ — raises E-utilities rate limit (3→10 req/s)
NCBI_API_KEY=

# GEO dataset discovery — max records to retrieve and rank per query (default 15, cap 200)
GEO_MAX_RESULTS=50

# Expression Atlas — max experiments to retrieve per query (default 10, cap 50)
EXPRESSION_ATLAS_MAX_RESULTS=10

# ImmPort — max shared studies to retrieve per query (default 10, cap 50)
IMMPORT_MAX_RESULTS=10
# Include text_broad supplemental free-text strategy by default (true|false)
SCIAGENT_IMMPORT_TEXT_BROAD=true

# Vivli / AccessClinicalData@NIAID — max clinical trial records per query (default 10, cap 50)
VIVLI_MAX_RESULTS=10

# OmicsDI — max datasets to retrieve per query (default 10, cap 50)
OMICSDI_MAX_RESULTS=10

# ProteomeXchange — max datasets to retrieve per query (default 10, cap 50)
PROTEOMEXCHANGE_MAX_RESULTS=10

# VDJServer — max immune repertoire studies to retrieve per query (default 10, cap 50)
VDJSERVER_MAX_RESULTS=10

# OpenAlex politeness
OPENALEX_EMAIL=

# Optional LLM facet extraction fallback for dataset discovery (requires ANTHROPIC_API_KEY).
# Set SCIAGENT_LLM_INTERPRET=false to disable even when the key is present.
SCIAGENT_LLM_INTERPRET=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# BioPortal ontology lookup (tier 2) — free at bioportal.bioontology.org
BIOPORTAL_API_KEY=
MAX_TOKENS=1000
TEMPERATURE=0.7

# Frontend (Vercel build-time only)
# VITE_API_BASE=https://your-render-service.onrender.com
